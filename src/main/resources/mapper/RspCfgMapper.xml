<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.mapper.RspCfgMapper">

    <resultMap id="RspCfgResultMap" type="com.example.entity.RspCfg">
        <result property="wkeCode" column="wke_code"/>
        <result property="xpath" column="xpath"/>
        <result property="ddzName" column="ddz_name"/>
        <result property="fieldName" column="field_name"/>
        <result property="fieldSeq" column="field_seq"/>
        <result property="multiTag" column="multi_tag"/>
    </resultMap>

    <select id="selectByWkeCode" resultMap="RspCfgResultMap">
        SELECT wke_code,
               xpath,
               ddz_name,
               field_name,
               field_seq,
               multi_tag
        FROM rsp_cfg_t
        WHERE wke_code = #{wkeCode}
        ORDER BY field_seq ASC
    </select>

</mapper>
