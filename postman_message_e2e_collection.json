        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"wkeCode\": \"{{wkeCode}}\",\n  \"xml\": \"<FIToFICstmrCdtTrf>\\n    <GrpHdr>\\n        <MsgId>123456789</MsgId>\\n        <CreDtTm>20260404</CreDtTm>\\n        <NbOfTxs>88</NbOfTxs>\\n        <SttlmInf>\\n            <SttlmMtd>abcd</SttlmMtd>\\n            <SttlmMtd>efgh</SttlmMtd>\\n            <SttlmMtd>hijk</SttlmMtd>\\n        </SttlmInf>\\n    </GrpHdr>\\n    <CdtTrfTxInf>\\n        <PmtId>\\n            <EndToEndId>2425200635</EndToEndId>\\n            <TxId>422827199603170215</TxId>\\n        </PmtId>\\n        <PmtId>\\n            <EndToEndId>2425200635</EndToEndId>\\n            <TxId>422827199603170215</TxId>\\n        </PmtId>\\n        <InstrId>2358680257</InstrId>\\n        <InstrId>2358680258</InstrId>\\n        <XchgRate>0.1</XchgRate>\\n        <Amt Ccy=\\\"CNY\\\">2784245.00</Amt>\\n    </CdtTrfTxInf>\\n    <CdtTrfTxInf>\\n        <PmtId>\\n            <EndToEndId>2425200636</EndToEndId>\\n            <TxId>422827199603170216</TxId>\\n        </PmtId>\\n        <PmtId>\\n            <EndToEndId>2425200636</EndToEndId>\\n            <TxId>422827199603170216</TxId>\\n        </PmtId>\\n        <InstrId>2358680259</InstrId>\\n        <InstrId>2358680210</InstrId>\\n        <XchgRate>0.2</XchgRate>\\n        <Amt Ccy=\\\"USD\\\">8888.88</Amt>\\n    </CdtTrfTxInf>\\n</FIToFICstmrCdtTrf>\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/message/e2e/xml-to-ddz",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "message",
            "e2e",
            "xml-to-ddz"
          ]
        },
        "description": "将XML报文转换为DDZ结构，并返回签名串"
      },
      "response": []
    },
    {
