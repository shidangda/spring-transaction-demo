          "raw": "{\n  \"wkeCode\": \"{{wkeCode}}\",\n  \"dtoMap\": {\n    \"X1\": [\n      {\n        \"MsgId\": \"MSG20260406001\",\n        \"NbOfTxs\": \"1\",\n        \"X5\": [\n          {\n            \"InstrId\": \"INS001\"\n          }\n        ],\n        \"X4\": [\n          {\n            \"EndToEndId\": \"E2E001\",\n            \"TxId\": \"TX001\"\n          }\n        ]\n      }\n    ]\n  }\n}"
        },
        "url": {
