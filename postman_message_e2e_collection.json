{
  "info": {
    "_postman_id": "3d5e8cb1-3f88-4b92-9a77-6bba4a7d1f01",
    "name": "spring-transaction-demo message e2e",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "XML <-> DDZ 端到端测试接口集合"
  },
  "item": [
    {
      "name": "XML -> DDZ",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"wkeCode\": \"{{wkeCode}}\",\n  \"xml\": \"<Document><GrpHdr><MsgId>MSG20260406001</MsgId><NbOfTxs>1</NbOfTxs></GrpHdr><PmtInf><PmtInfId>PMT001</PmtInfId><CdtTrfTxInf><PmtId><InstrId>INS001</InstrId><EndToEndId>E2E001</EndToEndId><TxId>TX001</TxId></PmtId></CdtTrfTxInf></PmtInf></Document>\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/message/e2e/xml-to-ddz",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "message",
            "e2e",
            "xml-to-ddz"
          ]
        },
        "description": "将XML报文转换为DDZ结构，并返回签名串"
      },
      "response": []
    },
    {
      "name": "DDZ -> XML",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"wkeCode\": \"{{wkeCode}}\",\n  \"dtoMap\": {\n    \"X1\": [\n      {\n        \"MsgId\": \"MSG20260406001\",\n        \"NbOfTxs\": \"1\",\n        \"X5\": [\n          {\n            \"InstrId\": \"INS001\"\n          }\n        ],\n        \"X4\": [\n          {\n            \"EndToEndId\": \"E2E001\",\n            \"TxId\": \"TX001\"\n          }\n        ]\n      }\n    ]\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/message/e2e/ddz-to-xml",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "message",
            "e2e",
            "ddz-to-xml"
          ]
        },
        "description": "将DDZ结构转换为XML报文，并返回签名串"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "wkeCode",
      "value": "DEMO_WKE"
    }
  ]
}
